{
  "name": "screenshot-mcp",
  "private": true,
  "version": "1.0.0",
  "description": "MCP server for generating screenshots via Playwright",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "screenshot-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mcp",
    "screenshot",
    "playwright",
    "og-image"
  ],
  "author": "84em.io",
  "license": "MIT"
}
