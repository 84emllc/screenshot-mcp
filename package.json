{
	"name": "screenshot-mcp",
	"private": true,
	"version": "1.1.0",
	"description": "MCP server for generating screenshots via Playwright",
	"type": "module",
	"main": "dist/index.js",
	"files": [
		"dist",
		"assets/frames/**"
	],
	"bin": {
		"screenshot-mcp": "dist/index.js",
		"responsive-mockup": "dist/cli/mockup.js"
	},
	"scripts": {
		"build": "rm -rf dist && tsc && chmod +x dist/index.js dist/cli/mockup.js",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"playwright": "^1.52.0",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^3.2.4"
	},
	"keywords": [
		"mcp",
		"screenshot",
		"playwright",
		"og-image"
	],
	"author": "84em.io",
	"license": "MIT"
}
